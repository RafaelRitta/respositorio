
<%- include('../cabecalho.ejs')%>

    <main class="container">
        <div class="page-header">
            <h2>Lista de Artistas</h2>
            <a href="/artista/add" class="btn btn-success">+ Novo Artista</a>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Editar</th>
                        <th>Excluir</th>
                    </tr>
                </thead>
                <tbody>
                    <%artista.forEach(artista => {%>
                    <tr>
                        <td><%=artista.nome%></td>
                        <td><a href="/artista/edt/<%=artista._id%>">Editar</a></td>
                        <td><a href="/artista/del/<%=artista._id%>">Excluir</a></td>
                    </tr>
                    <%})%>
                </tbody>
            </table>
        </div>
    </main>

<%- include('../rodape.ejs')%>
