
<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/instrumento/lst" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Novo Instrumento</h2>
            
            <form method="post" >
                <div class="form-group">
                    <label for="nome">Nome</label>
                    <input 
                        type="text" 
                        id="nome" 
                        name="nome" 
                        
                    >
                    <label for="tipo">Tipo</label>
                    <input
                    type="text"
                    id="tipo"
                    name="tipo"
                    >
                </div>


                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="instrumento/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>